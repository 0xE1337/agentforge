# =============================================================================
# Supabase (realtime payment events for the dashboard)
# https://app.supabase.com/project/_/settings/api
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# x402 / Circle Nanopayments wallets
# Run `npm run generate-wallets` to auto-generate both wallets, then fund them
# from https://faucet.circle.com (Arc Testnet, 10 USDC per claim).
# =============================================================================
# Seller (skill provider — receives payments)
SELLER_ADDRESS=0xYourSellerAddress
SELLER_PRIVATE_KEY=0xYourSellerPrivateKey

# Buyer (orchestrator agent — pays for skill calls)
BUYER_ADDRESS=0xYourBuyerAddress
BUYER_PRIVATE_KEY=0xYourBuyerPrivateKey

# =============================================================================
# Arc Testnet contract addresses
# Replace with your own deployments, or reuse the ones in README.md if you only
# want to interact with the existing on-chain registry.
# =============================================================================
NEXT_PUBLIC_SKILL_REGISTRY_ADDRESS=0x27853b1D8c6E38A86B99597A2e5334c15F532f21
NEXT_PUBLIC_PAYMENT_GUARD_ADDRESS=0x80a5FfE02BFB34dF0C05541c47b77182391bE3B1
NEXT_PUBLIC_MARKETPLACE_FEE_ADDRESS=0xD321f3BD1f7E8bBA574151323614Ec2E4faD3ACB

# =============================================================================
# LLM — used by social-intel + summarizer skills and by the orchestrator for
# task decomposition and result aggregation.
#
# Tried in order: OpenAI (primary) → DeepSeek (fallback). Each provider has a
# 15s timeout; a hanging upstream auto-fails over to the next. Either alone
# works; configuring both gives demo-time failover.
# =============================================================================
# OpenAI primary — get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
# Override default model (gpt-4o-mini is fast + cheap, ideal for demo latency)
# OPENAI_MODEL=gpt-4o-mini

# DeepSeek fallback — get a key at https://platform.deepseek.com
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# "deepseek-chat" auto-tracks latest stable; pin a version with DEEPSEEK_MODEL
# DEEPSEEK_MODEL=deepseek-chat

# =============================================================================
# Optional — CLI / local dev overrides
# =============================================================================
# BASE_URL: where CLI scripts hit the API (defaults to http://localhost:3000)
# BASE_URL=http://localhost:3000

# DEPOSIT_AMOUNT: USDC to deposit into the Circle Gateway on agent startup
# (defaults to 1 USDC). Used by agent.mts / orchestrator.mts.
# DEPOSIT_AMOUNT=1
